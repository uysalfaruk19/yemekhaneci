# =====================================================================
# Yemekhaneci.com.tr — Ortam Değişkenleri (örnek)
# Kopyala: cp .env.example .env  (asla repo'ya commit etme)
# =====================================================================

# --- Uygulama ---
APP_NAME="Yemekhaneci"
APP_ENV=local                        # local | staging | production
APP_DEBUG=true                       # production'da false
APP_URL=http://localhost:8000
APP_TIMEZONE=Europe/Istanbul
APP_LOCALE=tr
APP_KEY=                             # `php artisan key:generate` ile üret

# --- Veritabanı (MySQL 8) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=yemekhaneci
DB_USERNAME=yemekhaneci
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_turkish_ci

# --- Test veritabanı ---
DB_TEST_DATABASE=yemekhaneci_test

# --- Redis (cache, queue, rate limit, session) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# --- Cache / Session / Queue sürücüleri ---
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120                 # dakika
SESSION_SECURE_COOKIE=true           # production'da true
SESSION_SAME_SITE=lax
QUEUE_CONNECTION=redis

# --- Mail (PostMark birincil, SendGrid yedek) ---
MAIL_MAILER=postmark
MAIL_FROM_ADDRESS=hello@yemekhaneci.com.tr
MAIL_FROM_NAME="${APP_NAME}"
POSTMARK_TOKEN=
SENDGRID_API_KEY=

# --- SMS (Netgsm birincil, İletimerkezi yedek) ---
SMS_PROVIDER=netgsm                  # netgsm | iletimerkezi
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_HEADER=YEMEKHANECI            # onaylı başlık
ILETIMERKEZI_USERNAME=
ILETIMERKEZI_PASSWORD=

# --- Ödeme (iyzico birincil, PayTR taksit/B2B) ---
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com   # production: https://api.iyzipay.com
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1

# --- E-Fatura (ParamPos veya Foriba) ---
EFATURA_PROVIDER=parampos            # parampos | foriba
PARAMPOS_USERNAME=
PARAMPOS_PASSWORD=
FORIBA_USERNAME=
FORIBA_PASSWORD=

# --- Object Storage (Backblaze B2 — yedek + uploads) ---
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=yemekhaneci-prod
B2_REGION=eu-central-003
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com

# --- CDN (Cloudflare) ---
CDN_URL=https://cdn.yemekhaneci.com.tr

# --- Arama (Meilisearch — Faz 5+) ---
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# --- İzleme ---
SENTRY_DSN=
UPTIMEROBOT_KEY=

# --- Güvenlik / 2FA ---
ENCRYPTION_KEY=                      # 32 byte rastgele
ADMIN_2FA_REQUIRED=true              # admin için zorunlu
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_REGISTER_PER_HOUR=3
RATE_LIMIT_LEAD_PER_HOUR=10

# --- KVKK / Çerez ---
COOKIE_BANNER_ENABLED=true
KVKK_CONTACT_EMAIL=kvkk@yemekhaneci.com.tr

# --- Komisyon (PRD bölüm 12) ---
COMMISSION_DIRECT_MIN=8
COMMISSION_DIRECT_MAX=12
COMMISSION_REACTIVE_MIN=5
COMMISSION_REACTIVE_MAX=7
COMMISSION_PROACTIVE_MIN=8
COMMISSION_PROACTIVE_MAX=12
COMMISSION_B2B_MIN=3
COMMISSION_B2B_MAX=5
COMMISSION_FREE_PILOT_MONTHS=6       # ilk 6 ay sıfır komisyon

# --- Dosya yükleme limitleri ---
UPLOAD_IMAGE_MAX_KB=5120             # 5 MB
UPLOAD_PDF_MAX_KB=10240              # 10 MB
UPLOAD_ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp
UPLOAD_ALLOWED_PDF_MIME=application/pdf

# --- Harita (Leaflet + OSM, ücretsiz) ---
OSM_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
