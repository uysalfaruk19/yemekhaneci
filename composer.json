{
    "name": "uysa/yemekhaneci",
    "description": "Yemekhaneci.com.tr — Türkiye'nin tarafsız catering pazaryeri (UYSA Yemek Hizmetleri).",
    "type": "project",
    "license": "proprietary",
    "homepage": "https://yemekhaneci.com.tr",
    "keywords": ["catering", "yemekhane", "marketplace", "turkey", "uysa"],
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.7",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test-unit": "phpunit --testsuite=Unit",
        "serve": "@php -S 127.0.0.1:8000 -t public/ public/index.php",
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
